{
  "name": "nagarlens-ai",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "AI-powered hyperlocal civic issue reporting, verification and resolution tracking built for Vibe2Ship 2026.",
  "scripts": {
    "dev": "concurrently -k -n WEB,API -c auto \"vite --host 0.0.0.0\" \"tsx watch server/index.ts\"",
    "build": "tsc --noEmit && vite build",
    "start": "tsx server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/genai": "2.9.0",
    "cors": "2.8.5",
    "dotenv": "17.3.1",
    "exifr": "^7.1.3",
    "express": "5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "8.1.0",
    "leaflet": "^1.9.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-leaflet": "^5.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "10.0.3",
    "jsdom": "29.0.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  },
  "allowScripts": {
    "@google/genai@2.9.0": true,
    "esbuild@0.28.1": true,
    "protobufjs@7.6.4": true
  }
}
