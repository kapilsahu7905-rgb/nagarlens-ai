rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }

    match /issues/{issueId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.id == issueId
        && request.resource.data.analysis is map
        && request.resource.data.createdAt is string;
      allow update: if signedIn()
        && request.resource.data.id == resource.data.id
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;

      match /verifications/{verificationId} {
        allow read: if signedIn();
        allow create, update: if signedIn() && verificationId == request.auth.uid;
        allow delete: if false;
      }
    }

    match /profiles/{profileId} {
      allow read: if true;
      allow create: if signedIn() && profileId == request.auth.uid;
      allow update: if signedIn() && profileId == request.auth.uid;
      allow delete: if false;

      match /xpEvents/{eventId} {
        allow read: if true;
        allow create, update, delete: if signedIn() && profileId == request.auth.uid;
      }
    }
  }
}
