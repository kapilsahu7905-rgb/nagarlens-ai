# Required for real Gemini analysis. Add this as an AI Studio secret named GEMINI_API_KEY.
GEMINI_API_KEY=replace_with_your_key
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite

# Set true only for UI testing without Gemini. Demo responses are visibly labelled.
DEMO_MODE=false
PORT=3001

# Optional Firebase web configuration. These values are not private secrets.
# Enable Anonymous Authentication, Firestore and Storage in Firebase Console.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
